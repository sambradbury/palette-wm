{
  "name": "palette-wm",
  "version": "0.1.0",
  "description": "Lightweight CLI for managing multi-repo projects using git worktrees",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "git",
    "worktree",
    "monorepo",
    "multi-repo",
    "cli",
    "workspace",
    "developer-tools"
  ],
  "homepage": "https://github.com/sambradbury/palette-wm#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sambradbury/palette-wm.git"
  },
  "files": [
    "dist/"
  ],
  "bin": {
    "palette": "./dist/cli.js",
    "pal": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm && printf '#!/usr/bin/env node\n' | cat - dist/cli.js > dist/cli.js.tmp && mv dist/cli.js.tmp dist/cli.js",
    "prepublishOnly": "bun run build",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
